# Copy this file to .env and fill in your values
# Never commit .env to version control

# LLM provider: groq (default, free API) or ollama (fully offline, no API key needed)
LLM_PROVIDER=groq

# Groq API key - required when LLM_PROVIDER=groq
# Free tier, no credit card required - sign up at https://console.groq.com
GROQ_API_KEY=gsk_...

# CORS - comma-separated origins (default: localhost dev ports)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ollama settings - required when LLM_PROVIDER=ollama
# OLLAMA_HOST=http://ollama:11434   # use http://localhost:11434 for local dev without Docker
# OLLAMA_MODEL=llama3.2
